# ── mngm.com Credentials ──────────────────────────────────────────────────────
MNGM_EMAIL=your@email.com
MNGM_PASSWORD=your_password

# ── Notifications ──────────────────────────────────────────────────────────────
NOTIFY_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

# ── Telegram Bot (get from @BotFather on Telegram) ────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
# Get your chat_id by messaging your bot then visiting:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=987654321

# ── Trading Strategy ───────────────────────────────────────────────────────────
SELL_TARGET_PCT=0.7          # Sell when position up X%
DIP_BUY_PCT=0.5              # Buy when price dips X% from peak
LOW_WALLET_THRESHOLD=500     # Minimum EGP wallet balance to trigger a buy

# ── Upstash Redis (get from upstash.com → create free Redis database) ─────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Vercel Cron Security ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ── Dashboard Display ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SELL_TARGET_PCT=0.7

# ── EGX (Egyptian Exchange) ───────────────────────────────────────────────────
# No extra keys needed — uses TradingView's public screener API.
# The daily brief fires automatically at 10:00 AM Cairo time via the internal scheduler.
# To manually trigger: GET /api/cron/egx?force=1
